# Klaxxon web frontend — served by Caddy on the web LXC (.12)
#
# Serves the SPA at the root. Proxies /api/* to the API LXC (.11).
# Uses mutual TLS between Caddy and the API backend.
# External access via self-signed cert (generated by deploy/gen-certs.sh).

{
    auto_https off
}

:443 {
    tls /etc/klaxxon/certs/web.crt /etc/klaxxon/certs/web.key

    # Serve the SPA
    root * /srv/klaxxon/web
    file_server

    # Proxy API requests to the API LXC
    handle /api/* {
        reverse_proxy https://192.168.1.11:8443 {
            transport http {
                tls_client_auth /etc/klaxxon/certs/web.crt /etc/klaxxon/certs/web.key
                tls_trusted_ca_certs /etc/klaxxon/certs/ca.crt
            }
        }
    }

    # Proxy one-time ack token links to the API LXC (no auth required, REQ-14)
    handle /ack/* {
        reverse_proxy https://192.168.1.11:8443 {
            transport http {
                tls_client_auth /etc/klaxxon/certs/web.crt /etc/klaxxon/certs/web.key
                tls_trusted_ca_certs /etc/klaxxon/certs/ca.crt
            }
        }
    }

    # SPA fallback: serve index.html for all non-file routes
    try_files {path} /index.html

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy camera=(), microphone=(), geolocation=()
    }

    log {
        output file /var/log/klaxxon/access.log
        format json
    }
}
